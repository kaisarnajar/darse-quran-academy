{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/**/{page,layout,loading,error,not-found,route,default,global-error}.{js,jsx,ts,tsx}",
    "prisma/seed*.ts",
    "scripts/*.{mjs,js}"
  ],
  "project": ["**/*.{ts,tsx,mjs}"],
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": ["tailwindcss", "@types/bcryptjs"]
}
