generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Occupation {
  STUDENT
  WORKING
  GOVERNMENT_EMPLOYEE
  SELF_EMPLOYED
  LABOURER
  POLICE_OFFICER
  ARMED_FORCES
  TEACHER
  HEALTHCARE_WORKER
  ENGINEER
  IT_PROFESSIONAL
  ACCOUNTANT
  LAWYER
  DRIVER
  FARMER
  SHOPKEEPER
  CLERGY
  HOMEMAKER
  RETIRED
  UNEMPLOYED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ONGOING
  COMPLETED
  ON_HOLD
}

enum AnnouncementCategory {
  EXAMS_TESTS
  ASSIGNMENTS_HOMEWORK
  STUDY_MATERIALS
  CLASS_SCHEDULE
  COURSE_ANNOUNCEMENT
  GENERAL_NOTICE
}

enum DailyInspirationKind {
  QURAN
  HADITH
}

enum BlogApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum StudentReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StudentNotificationType {
  PAYMENT_APPROVED
  ENROLLMENT_APPROVED
  ENROLLMENT_REJECTED
  COURSE_ANNOUNCEMENT
  PERSONAL_MESSAGE
  SITE_ANNOUNCEMENT
  BOOK_ORDER_APPROVED
  BOOK_ORDER_DECLINED
  BOOK_ORDER_SHIPPED
  BOOK_ORDER_REFUNDED
}

enum BookStatus {
  AVAILABLE
  OUT_OF_STOCK
  COMING_SOON
}

enum BookOrderStatus {
  PENDING_VERIFICATION
  APPROVED
  DECLINED
  SHIPPED
  REFUNDED
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  fatherName    String?
  dateOfBirth   DateTime?
  occupation    Occupation?
  address       String?
  whatsapp      String?
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  enrollments              Enrollment[]
  paymentRecords           PaymentRecord[]
  coursePaymentSubmissions CoursePaymentSubmission[]
  fatwaQuestions     FatwaQuestion[]
  fatwaAnswers       FatwaQuestion[] @relation("FatwaAnsweredBy")
  contactInquiries   ContactInquiry[]
  contactReplies     ContactInquiry[] @relation("ContactInquiryRepliedBy")
  siteAnnouncements  SiteAnnouncement[] @relation("SiteAnnouncementAuthor")
  blogPosts          BlogPost[]         @relation("BlogPostAuthor")
  dailyInspirations  DailyInspiration[] @relation("DailyInspirationAuthor")
  studentReviews       StudentReview[]
  studentNotifications StudentNotification[]
  bookOrders           BookOrder[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

/** One-time tokens for email password reset (hashed at rest). */
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Course {
  id            String   @id
  title         String
  description   String
  startDate     String
  duration      String
  level         String
  category      String
  priceInrPaise       Int
  monthlyFeeInrPaise  Int
  teacherId           String?
  status              CourseStatus @default(PUBLISHED)
  featuredOnHomepage  Boolean      @default(false)
  featuredAt          DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  teacher         Teacher?              @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  paymentRecords  PaymentRecord[]
  announcements   CourseAnnouncement[]

  @@index([featuredOnHomepage, featuredAt])
  @@index([teacherId])
}

model Teacher {
  id             String   @id
  name           String
  email          String?  @unique
  specialization String
  bio            String
  initials       String
  imageUrl       String?
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  courses        Course[]
  announcements  CourseAnnouncement[]
  expenses       Expense[]
}

model CourseAnnouncement {
  id             String               @id @default(cuid())
  courseId       String
  enrollmentId   String?
  teacherId      String?
  authorName     String
  postedByAdmin  Boolean              @default(false)
  category       AnnouncementCategory
  title          String
  body           String
  attachmentPath String?
  attachmentName String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  course         Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollment     Enrollment?          @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  teacher        Teacher?             @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  @@index([courseId])
  @@index([courseId, createdAt])
  @@index([enrollmentId])
  @@index([courseId, enrollmentId])
}

model SiteAnnouncement {
  id             String   @id @default(cuid())
  title          String
  body           String
  eventDate      String?
  location       String?
  showOnHomepage Boolean  @default(false)
  published      Boolean  @default(true)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      User?    @relation("SiteAnnouncementAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([published, showOnHomepage])
  @@index([published, createdAt])
}

model BlogPost {
  id             String             @id @default(cuid())
  title          String
  excerpt        String?
  body           String
  published      Boolean            @default(false)
  approvalStatus BlogApprovalStatus @default(APPROVED)
  featuredOnHomepage Boolean            @default(false)
  featuredAt         DateTime?
  createdById    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdBy      User?              @relation("BlogPostAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  images         BlogImage[]

  @@index([published, approvalStatus, createdAt])
  @@index([approvalStatus, createdAt])
  @@index([featuredOnHomepage, featuredAt])
}

model BlogImage {
  id         String   @id @default(cuid())
  blogPostId String
  imagePath  String
  caption    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@index([blogPostId, sortOrder])
}

model DailyInspiration {
  id                 String               @id @default(cuid())
  kind               DailyInspirationKind
  arabicText         String
  englishTranslation String
  reference          String?
  published          Boolean              @default(false)
  createdById        String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  createdBy          User?                @relation("DailyInspirationAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([published, updatedAt])
}

model StudentReview {
  id                 String               @id @default(cuid())
  userId             String
  quote              String
  course             String?
  location           String?
  rating             Int                  @default(5)
  status             StudentReviewStatus  @default(PENDING)
  featuredOnHomepage Boolean              @default(false)
  featuredAt         DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([featuredOnHomepage, featuredAt])
  @@index([userId, status])
}

model LibraryItem {
  id        String   @id
  title     String
  author    String
  topic     String
  level     String
  language  String
  pdfUrl              String?
  imagePath           String?
  published           Boolean  @default(true)
  featuredOnHomepage  Boolean  @default(false)
  featuredAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([featuredOnHomepage, featuredAt])
}

model Enrollment {
  id               String   @id @default(cuid())
  userId           String
  courseId         String
  status           String   @default("pending_approval")
  certificateNumber String? @unique
  certificateGeneratedAt DateTime?
  certificateType        String?
  certificateGrade       Int?
  completedAt               DateTime?
  certificateEmailSentAt    DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcements    CourseAnnouncement[]

  @@unique([userId, courseId])
  @@index([courseId])
}

model FatwaQuestion {
  id           String    @id @default(cuid())
  userId       String?
  askerName    String
  askerEmail   String
  category     String
  title        String
  question     String
  answer               String?
  answeredAt           DateTime?
  answeredById         String?
  featuredOnHomepage   Boolean   @default(false)
  featuredAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  answeredBy   User?     @relation("FatwaAnsweredBy", fields: [answeredById], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([answeredAt])
  @@index([featuredOnHomepage, featuredAt])
}

model ContactInquiry {
  id          String    @id @default(cuid())
  userId      String?
  name        String
  email       String
  phone       String
  message     String
  reply       String?
  repliedAt   DateTime?
  repliedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  repliedBy   User?     @relation("ContactInquiryRepliedBy", fields: [repliedById], references: [id], onDelete: SetNull)

  @@index([repliedAt])
  @@index([createdAt])
}

model PaymentRecord {
  id                   String   @id @default(cuid())
  userId               String
  courseId             String?
  amountInrPaise       Int
  paidAt               DateTime
  paymentType          String?
  invoiceNumber        String?  @unique
  description          String?
  receiptEmailSentAt   DateTime?
  receiptGeneratedAt   DateTime?
  receiptIncludesGst   Boolean?
  receiptFeeAmountPaise Int?
  receiptGstAmountPaise Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  submission     CoursePaymentSubmission?

  @@index([userId])
  @@index([paidAt])
  @@index([courseId])
  @@index([paymentType])
}

/** Academy operational expenses (salaries, hosting, etc.). */
model Expense {
  id             String   @id @default(cuid())
  category       String
  amountInrPaise Int
  paidAt         DateTime
  description    String?
  teacherId      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  teacher        Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([paidAt])
  @@index([teacherId])
}

/** Social and WhatsApp links (single row, id = "default"). Editable in admin. */
model SocialLinksSettings {
  id                     String   @id @default("default")
  contactEmail           String   @default("info@darsequranacademy.org")
  whatsappNumber         String   @default("919622966911")
  whatsappDefaultMessage String   @default("Assalamu Alaikum, I would like to know more about Darse Quran Academy.")
  facebookUrl            String   @default("https://facebook.com")
  instagramUrl           String   @default("https://instagram.com")
  youtubeUrl             String   @default("https://youtube.com")
  updatedAt              DateTime @updatedAt
}

/** Core academy info (single row, id = "default"). Editable in admin. */
model AcademySettings {
  id             String   @id @default("default")
  academyName    String   @default("Darse Quran Academy")
  academyAddress String   @default("Treran Tangmarg, Baramulla J&K 193402")
  academyWebsite String   @default("www.darsequranacademy.com")
  updatedAt      DateTime @updatedAt
}

/** Academy UPI and bank details (single row, id = "default"). Editable in admin. */
model PaymentSettings {
  id                String   @id @default("default")
  upiId             String   @default("")
  upiPayeeName      String   @default("Darse Quran Academy")
  bankAccountName   String   @default("Darse Quran Academy")
  bankName          String   @default("")
  bankAccountNumber String   @default("")
  bankIfsc          String   @default("")
  bankBranch        String   @default("")
  updatedAt         DateTime @updatedAt
}

/** Student-submitted monthly or enrollment course fees awaiting admin approval. */
model CoursePaymentSubmission {
  id                    String    @id @default(cuid())
  userId                String
  courseId              String
  paymentType           String    @default("monthly")
  label                 String
  amountInrPaise        Int
  status                String    @default("pending_verification")
  paymentMethod         String?
  upiTransactionId      String?
  paymentScreenshotPath String?
  paymentReference      String?   @unique
  paymentRecordId       String?   @unique
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentRecord         PaymentRecord? @relation(fields: [paymentRecordId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@index([paymentType])
}

model StudentNotification {
  id         String                  @id @default(cuid())
  userId     String
  type       StudentNotificationType
  title      String
  body       String?
  href       String
  readAt     DateTime?
  sourceType String?
  sourceId   String?
  createdAt  DateTime                @default(now())
  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, sourceId])
  @@index([userId, readAt])
  @@index([userId, createdAt])
}

/** Physical books available for purchase in the bookstore. */
model Book {
  id          String     @id @default(cuid())
  title       String
  author      String
  description String
  priceInrPaise Int
  purchasePriceInrPaise Int @default(0)
  inventoryPurchased Int @default(0)
  status      BookStatus @default(AVAILABLE)
  imagePath   String?
  published   Boolean    @default(true)
  featuredOnHomepage Boolean @default(false)
  featuredAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  orderItems  BookOrderItem[]

  @@index([status])
  @@index([published, status])
}

/** A user's book purchase order submitted for admin approval. */
model BookOrder {
  id                    String          @id @default(cuid())
  userId                String
  totalAmountInrPaise   Int
  status                BookOrderStatus @default(PENDING_VERIFICATION)
  paymentMethod         String?
  upiTransactionId      String?
  paymentScreenshotPath String?
  notes                 String?
  deliveryAddress       String          @default("No address provided")
  deliveryPinCode       String?
  deliveryPhoneNumber   String?
  courierServiceName    String?
  trackingId            String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items                 BookOrderItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

/** Line items in a book order. */
model BookOrderItem {
  id                   String    @id @default(cuid())
  orderId              String
  bookId               String
  quantity             Int       @default(1)
  priceAtPurchaseInrPaise Int
  createdAt            DateTime  @default(now())
  order                BookOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  book                 Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([bookId])
}

enum AnalyticsEventType {
  PAGE_VIEW
  BUTTON_CLICK
  CUSTOM
}

model AnalyticsEvent {
  id         String             @id @default(cuid())
  type       AnalyticsEventType
  page       String
  eventName  String?
  userId     String?
  createdAt  DateTime           @default(now())

  @@index([type])
  @@index([page])
  @@index([createdAt])
}
