generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  enrollments     Enrollment[]
  fatwaQuestions  FatwaQuestion[]
  fatwaAnswers    FatwaQuestion[] @relation("FatwaAnsweredBy")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Course {
  id            String   @id
  title         String
  description   String
  startDate     String
  level         String
  category      String
  priceInrPaise Int
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Teacher {
  id             String   @id
  name           String
  specialization String
  bio            String
  initials       String
  imageUrl       String?
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model LibraryItem {
  id        String   @id
  title     String
  author    String
  topic     String
  level     String
  language  String
  pdfUrl    String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enrollment {
  id               String   @id @default(cuid())
  userId           String
  courseId         String
  status           String   @default("pending")
  paymentReference String?  @unique
  upiTransactionId String?
  paymentMethod    String?  @default("upi")
  amountPaid              Int?
  currency                String?   @default("inr")
  completedAt             DateTime?
  certificateEmailSentAt  DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model FatwaQuestion {
  id           String    @id @default(cuid())
  userId       String?
  askerName    String
  askerEmail   String
  category     String
  title        String
  question     String
  answer       String?
  answeredAt   DateTime?
  answeredById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  answeredBy   User?     @relation("FatwaAnsweredBy", fields: [answeredById], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([answeredAt])
}
