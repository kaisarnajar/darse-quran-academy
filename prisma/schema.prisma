generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Occupation {
  STUDENT
  WORKING
  GOVERNMENT_EMPLOYEE
  SELF_EMPLOYED
  LABOURER
  POLICE_OFFICER
  ARMED_FORCES
  TEACHER
  HEALTHCARE_WORKER
  ENGINEER
  IT_PROFESSIONAL
  ACCOUNTANT
  LAWYER
  DRIVER
  FARMER
  SHOPKEEPER
  CLERGY
  HOMEMAKER
  RETIRED
  UNEMPLOYED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ONGOING
  COMPLETED
  ON_HOLD
}

enum AnnouncementCategory {
  EXAMS_TESTS
  ASSIGNMENTS_HOMEWORK
  STUDY_MATERIALS
  CLASS_SCHEDULE
  COURSE_ANNOUNCEMENT
  GENERAL_NOTICE
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  fatherName    String?
  dateOfBirth   DateTime?
  occupation    Occupation?
  address       String?
  whatsapp      String?
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  enrollments              Enrollment[]
  paymentRecords           PaymentRecord[]
  coursePaymentSubmissions CoursePaymentSubmission[]
  fatwaQuestions     FatwaQuestion[]
  fatwaAnswers       FatwaQuestion[] @relation("FatwaAnsweredBy")
  siteAnnouncements  SiteAnnouncement[] @relation("SiteAnnouncementAuthor")
  blogPosts          BlogPost[]         @relation("BlogPostAuthor")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Course {
  id            String   @id
  title         String
  description   String
  startDate     String
  level         String
  category      String
  priceInrPaise Int
  teacherId     String?
  status        CourseStatus @default(PUBLISHED)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  teacher         Teacher?              @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  paymentRecords  PaymentRecord[]
  announcements   CourseAnnouncement[]
}

model Teacher {
  id             String   @id
  name           String
  email          String?  @unique
  specialization String
  bio            String
  initials       String
  imageUrl       String?
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  courses        Course[]
  announcements  CourseAnnouncement[]
}

model CourseAnnouncement {
  id        String               @id @default(cuid())
  courseId  String
  teacherId String
  category  AnnouncementCategory
  title            String
  body             String
  attachmentPath   String?
  attachmentName   String?
  createdAt        DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  course    Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher   Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([courseId, createdAt])
}

model SiteAnnouncement {
  id             String   @id @default(cuid())
  title          String
  body           String
  eventDate      String?
  location       String?
  imagePath      String?
  showOnHomepage Boolean  @default(false)
  published      Boolean  @default(true)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      User?    @relation("SiteAnnouncementAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([published, showOnHomepage])
  @@index([published, createdAt])
}

model BlogPost {
  id          String      @id @default(cuid())
  title       String
  excerpt     String?
  body        String
  published   Boolean     @default(false)
  createdById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  createdBy   User?       @relation("BlogPostAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  images      BlogImage[]

  @@index([published, createdAt])
}

model BlogImage {
  id         String   @id @default(cuid())
  blogPostId String
  imagePath  String
  caption    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@index([blogPostId, sortOrder])
}

model LibraryItem {
  id        String   @id
  title     String
  author    String
  topic     String
  level     String
  language  String
  pdfUrl    String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enrollment {
  id               String   @id @default(cuid())
  userId           String
  courseId         String
  status           String   @default("pending")
  paymentReference String?  @unique
  upiTransactionId       String?
  paymentMethod          String?  @default("upi")
  paymentScreenshotPath  String?
  amountPaid              Int?
  currency                String?   @default("inr")
  completedAt             DateTime?
  certificateEmailSentAt  DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model FatwaQuestion {
  id           String    @id @default(cuid())
  userId       String?
  askerName    String
  askerEmail   String
  category     String
  title        String
  question     String
  answer       String?
  answeredAt   DateTime?
  answeredById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  answeredBy   User?     @relation("FatwaAnsweredBy", fields: [answeredById], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([answeredAt])
}

model PaymentRecord {
  id             String   @id @default(cuid())
  userId         String
  courseId       String?
  amountInrPaise Int
  paidAt         DateTime
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  submission     CoursePaymentSubmission?

  @@index([userId])
  @@index([paidAt])
}

/** Student-submitted monthly (or other) course fees awaiting admin approval. */
model CoursePaymentSubmission {
  id                    String    @id @default(cuid())
  userId                String
  courseId              String
  label                 String
  amountInrPaise        Int
  status                String    @default("pending_verification")
  paymentMethod         String?
  upiTransactionId      String?
  paymentScreenshotPath String?
  paymentReference      String?   @unique
  paymentRecordId       String?   @unique
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentRecord         PaymentRecord? @relation(fields: [paymentRecordId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([courseId])
  @@index([status])
}
