# ==========================================
# ACADEMY LMS - ENVIRONMENT VARIABLES
# ==========================================

# ------------------------------------------
# Authentication (NextAuth.js)
# ------------------------------------------
# The canonical URL of the application. Required for NextAuth, OAuth callbacks, and email links.
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Secret used to encrypt session tokens. Generate with: `openssl rand -base64 32`
AUTH_SECRET="your-auth-secret-here"

# Google OAuth Credentials (Optional)
# Used for Google Sign-In. Set up at: https://console.cloud.google.com/apis/credentials
# Authorized Redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ------------------------------------------
# Database (Neon / PostgreSQL)
# ------------------------------------------
# Connection string for Prisma Client (usually pooled)
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# Direct connection string for Prisma Migrations (non-pooled)
DIRECT_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# ------------------------------------------
# Role & Access Management
# ------------------------------------------
# Comma-separated email addresses granted full Admin access (must match sign-in email)
ADMIN_EMAIL="admin@youracademy.org,deputy@youracademy.org"

# Email address used for critical system alerts and developer debugging
DEVELOPER_EMAIL="developer@youracademy.org"

# ------------------------------------------
# Email Provider (Nodemailer / SMTP)
# ------------------------------------------
# Required for password resets, certificates, receipts, and fatwa updates.
# If unset, emails will gracefully fallback to console logs.
# For Gmail: Use an App Password (https://myaccount.google.com/apppasswords).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-academy@gmail.com"
SMTP_PASS="your-16-char-app-password"

# Display format for outgoing emails: "Display Name <email>"
EMAIL_FROM="Your Academy Name <your-academy@gmail.com>"

# Address where user replies should be directed
EMAIL_REPLY_TO="your-academy@gmail.com"

# ------------------------------------------
# File Storage (Cloudflare R2)
# ------------------------------------------
# Required for user uploads (announcements, library resources, user avatars).
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="your-r2-bucket-name"
R2_PUBLIC_URL="https://pub-your-id.r2.dev"

# ------------------------------------------
# Development & Testing (Optional)
# ------------------------------------------
# Set to 'true' to allow running 'npm run db:seed:demo' when NODE_ENV is production (e.g. for a staging environment).
# DO NOT enable in actual production environments!
# ALLOW_DEMO_SEED="true"
