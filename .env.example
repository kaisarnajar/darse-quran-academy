# App URL (required for NextAuth, OAuth callbacks, and links in emails)
AUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Database — local SQLite
DATABASE_URL="file:./dev.db"

# Production (Vercel + Neon): use PostgreSQL

# Administrators — comma-separated emails that can access /admin (must match sign-in email)
ADMIN_EMAIL=admin@youracademy.org,deputy@youracademy.org

# Google OAuth (optional) — https://console.cloud.google.com/apis/credentials
# Redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# UPI, bank, contact email, and social links are set in Admin (not in .env).

# Email (optional) — password reset, certificates, receipts, fatwa; logs to console if unset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Darse Quran Academy <your-email@gmail.com>"

# Demo seed guard (optional) — set to true to allow db:seed:demo on PostgreSQL / production (staging only)
# ALLOW_DEMO_SEED=true
