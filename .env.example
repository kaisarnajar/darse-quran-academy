# App URL (required for OAuth callbacks and links in emails)
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Database — local SQLite (no Docker required)
DATABASE_URL="file:./dev.db"

# Production (Vercel + Neon): use PostgreSQL — see docs/DEPLOYMENT.md

# Administrators — comma-separated emails that can access /admin (must match sign-in email)
ADMIN_EMAIL=admin@youracademy.org,deputy@youracademy.org

# Google OAuth (optional) — https://console.cloud.google.com/apis/credentials
# Redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email (optional) — certificate & fatwa notifications; logs to console if unset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Darse Quran Academy <your-email@gmail.com>"
