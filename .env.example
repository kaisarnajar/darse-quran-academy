# App URL (required for OAuth callbacks and links in emails)
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Database — PostgreSQL (required)
# Local with Docker: docker compose up -d
#   DATABASE_URL="postgresql://darse:darse@localhost:5432/darse"
# Production (Neon): use the connection string from console.neon.tech (include ?sslmode=require)
DATABASE_URL="postgresql://darse:darse@localhost:5432/darse"

# Administrator (must match the email used to sign in for /admin access)
ADMIN_EMAIL=admin@youracademy.org

# Google OAuth (optional) — https://console.cloud.google.com/apis/credentials
# Redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# UPI payments (required for course checkout)
UPI_ID=yourname@bank
UPI_PAYEE_NAME=Your Academy Name

# Email (optional) — certificate & fatwa notifications; logs to console if unset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Darse Quran Academy <your-email@gmail.com>"
