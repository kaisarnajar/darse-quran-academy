# App URL (required for OAuth callbacks)
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# Administrator (must match the email used to sign in)
ADMIN_EMAIL=admin@youracademy.org

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# UPI payments (your business UPI ID / VPA)
UPI_ID=kaisarnajar11114@okicici
UPI_PAYEE_NAME=Kaisar Najar

# Email (certificate notifications) — e.g. Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Darse Quran Academy <your-email@gmail.com>"
