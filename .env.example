# App URL (required for NextAuth, OAuth callbacks, and links in emails)
AUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Database — PostgreSQL
# PostgreSQL Database connection string
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# Administrators — comma-separated emails that can access /admin (must match sign-in email)
ADMIN_EMAIL=admin@youracademy.org,deputy@youracademy.org

# Google OAuth (optional) — https://console.cloud.google.com/apis/credentials
# Redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# UPI, bank, contact email, and social links are set in Admin (not in .env).

# Email (optional) — password reset, certificates, receipts, fatwa; logs to console if unset
# For Gmail personal (@gmail.com): enable 2-Step Verification, then create an App Password at
#   https://myaccount.google.com/apppasswords  (use that 16-char password as SMTP_PASS)
# Gmail DKIM + SPF are handled automatically by Google — no DNS changes required.
# For deliverability: SMTP_USER and EMAIL_FROM should use the same @gmail.com address.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-academy@gmail.com
SMTP_PASS=your-16-char-app-password
# EMAIL_FROM must use "Display Name <email>" format — display name shown in recipient's inbox
EMAIL_FROM="Darse Quran Academy <your-academy@gmail.com>"
# EMAIL_REPLY_TO — address replies go to (defaults to SMTP_USER if not set)
EMAIL_REPLY_TO=your-academy@gmail.com

# Demo seed guard (optional) — set to true to allow db:seed:demo with NODE_ENV=production (staging only)
# ALLOW_DEMO_SEED=true

